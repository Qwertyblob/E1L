# Copy to `.env` on the server (chmod 600) and fill in real values. NEVER commit the real .env.
# Consumed by docker-compose.yml for ${...} interpolation. The `app` container receives ONLY the
# explicit subset it needs (see the `environment:` block on the app service) — the Cloudflare tunnel
# token, the log-monitor PAT, and the R2 backup creds below are used by other processes and are
# deliberately NOT handed to the Spring app.

# --- Database (compose creates this role/db; app connects over the internal `data` network) ---
DB_USERNAME=every1luvs
DB_PASSWORD=change-me-strong-password
DATABASE_URL=jdbc:postgresql://db:5432/every1luvs

# --- Schema (Flyway runs db/migration/V*.sql at startup; Hibernate only validates) ---
DB_DDL_MODE=validate               # never `update` in prod — schema changes ship as new V<n>__*.sql migrations

# --- Auth / cookies (see every1luvs/src/main/resources/application.properties) ---
AUTH_TOKEN_SECRET=change-me-long-random-secret   # REQUIRED; generate e.g. `openssl rand -base64 48`
AUTH_COOKIE_SECURE=true            # REQUIRED in prod (HTTPS terminates at Cloudflare)
AUTH_COOKIE_SAME_SITE=Lax
TRUST_FORWARDED_FOR=true           # correct ONLY behind the nginx XFF-overwrite (see nginx/nginx.conf)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# --- Outbound mail via Brevo (free tier) ---
APP_MAIL_FROM=bookings@yourdomain.com
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-smtp-login
MAIL_PASSWORD=your-brevo-smtp-key
# Inbox for the per-booking admin notification (all details + inspo photos). Leave blank to fall
# back to APP_MAIL_FROM.
ADMIN_NOTIFICATION_EMAIL=

# --- Post-appointment review request ---
# Where the review email sends clients. If unset it defaults to the Instagram page
# (https://instagram.com/every1luvsnails), so the feature is ON by default. Set this to a dedicated
# review page (e.g. a Google Business "write a review" link) when you have one. Only COMPLETED
# bookings are ever asked (no no-shows). Leave commented/unset to keep the default (do NOT set it
# blank — an explicit empty value would disable the feature).
# REVIEW_URL=https://g.page/r/your-review-link

# --- Rebooking prompt (~3 weeks after the appointment) ---
# Where the "Book Your Next Appointment" button points. If unset it defaults to the site's services
# section (https://every1luvs.com/#services) where booking happens, so the feature is ON by default.
# Only COMPLETED bookings are nudged (no no-shows), once each, ~3 weeks after the visit. Leave
# commented/unset to keep the default (do NOT set it blank — an empty value disables the feature).
# BOOKING_URL=https://every1luvs.com/#services

# --- One-time admin bootstrap (INITIALIZATION ONLY) ---
# These are intentionally NOT part of the app service's `environment:` block, so the temp password
# is never permanently present in the running container. To create the first admin, pass them for a
# single boot via an override, e.g.:
#   BOOTSTRAP_ADMIN_ENABLED=true BOOTSTRAP_ADMIN_EMAIL=you@yourdomain.com \
#   BOOTSTRAP_ADMIN_PASSWORD=... docker compose run --rm \
#     -e BOOTSTRAP_ADMIN_ENABLED -e BOOTSTRAP_ADMIN_NAME -e BOOTSTRAP_ADMIN_EMAIL -e BOOTSTRAP_ADMIN_PASSWORD app
# then remove them from the environment. (Kept here only to document the variable names.)
# BOOTSTRAP_ADMIN_ENABLED=false
# BOOTSTRAP_ADMIN_NAME=Admin
# BOOTSTRAP_ADMIN_EMAIL=you@yourdomain.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-temp-password

# --- Cloudflare Tunnel (Zero Trust dashboard -> Tunnels -> token) ---
TUNNEL_TOKEN=your-cloudflare-tunnel-token

# --- Off-box backups (scripts/backup-to-r2.sh; rclone remote named `r2` must be configured) ---
R2_BUCKET=every1luvs-backups

# --- AI log-monitor (scripts/log-monitor.sh; fires repository_dispatch when prod errors appear) ---
GITHUB_REPO=Qwertyblob/E1L
# Fine-grained PAT scoped to ONLY this repo with Contents: read+write (the permission the
# dispatch API needs). Use a dedicated machine account so a leak is contained to one repo.
LOG_MONITOR_TOKEN=change-me-github-fine-grained-pat
# Optional tuning (defaults shown):
# LOG_MONITOR_MAX_PER_HOUR=3          # circuit breaker: max AI dispatches per rolling hour
# LOG_MONITOR_DEDUPE_TTL=21600        # re-alert on a recurring error signature at most every 6h
# LOG_MONITOR_SERVICES="app web db"   # which compose services to scan
# LOG_MONITOR_PATTERN="ERROR|FATAL|Exception"
# LOG_MONITOR_MAX_LINES=40            # cap on log lines bundled into the dispatch
